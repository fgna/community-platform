# .env.development.example — copy to .env for local development
#
# These values are safe for development only. Do NOT use them in production.
# For production, use .env.production.example instead.
#
# Quick start:
#   cp .env.development.example .env
#   docker compose up -d   (auto-loads docker-compose.override.yml for dev)

# ── Data directory ─────────────────────────────────────────────────────────────
DATA_DIR="./data"

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="dev-password-change-for-production"
POSTGRES_DB="community_platform"
DATABASE_URL="postgresql://postgres:dev-password-change-for-production@localhost:5432/community_platform"

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT Secrets (dev-only values — never use in production) ───────────────────
JWT_SECRET="dev-jwt-secret-replace-with-32-char-random-in-prod"
JWT_REFRESH_SECRET="dev-refresh-secret-replace-with-32-char-random"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Runtime ────────────────────────────────────────────────────────────────────
NODE_ENV="development"
API_PORT=3001
SEED_DEMO_DATA=true   # Creates demo accounts (admin@example.com / member@example.com)

# ── URLs (local) ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000"

# ── Domain (not used in dev — nginx/certbot profile not needed) ───────────────
DOMAIN="localhost"
SSL_EMAIL=""
SSL_STAGING=1

# ── Rate Limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=1000   # Relaxed for development

# ── Optional features (leave blank to disable) ────────────────────────────────
ANTHROPIC_API_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
NEXT_PUBLIC_LINKEDIN_CLIENT_ID=""
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@community.local"
NEXT_PUBLIC_APK_URL=""
