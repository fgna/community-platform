# Database
DATABASE_URL="postgresql://community:community@localhost:5432/community_platform"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-this-to-a-very-long-random-secret-key-in-production"
JWT_REFRESH_SECRET="change-this-to-another-very-long-random-secret-key"
JWT_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# API
API_PORT=3001
API_URL="http://localhost:3001"
CORS_ORIGINS="http://localhost:3000"

# Web
NEXT_PUBLIC_API_URL="http://localhost:3001/api"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Community Platform"

# Admin
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="Admin123!@#"
ADMIN_NAME="Platform Admin"

# Rate limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Node
NODE_ENV="development"
