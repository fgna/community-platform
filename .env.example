# Data directory — all persistent data (database, uploads, backups) is stored here.
# This directory lives OUTSIDE Docker and survives rebuilds, updates, and `docker compose down`.
# Back up this single folder to protect all community data.
DATA_DIR="./data"

# Database
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="change-me-in-production"
POSTGRES_DB="community_platform"
DATABASE_URL="postgresql://postgres:password@localhost:5432/community_platform"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# API
API_PORT=3001
API_URL="http://localhost:3001"
NODE_ENV="development"

# Web
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-change-in-production"

# OAuth (optional — leave empty to disable social login buttons)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
NEXT_PUBLIC_LINKEDIN_CLIENT_ID=""

# AI Coach (optional — leave empty to disable AI Coach feature)
ANTHROPIC_API_KEY=""

# Stripe Billing (optional — leave empty to disable billing features)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Admin
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="Admin123!@#"

# CORS
CORS_ORIGINS="http://localhost:3000"

# HTTPS / Reverse Proxy (enable with: docker compose --profile proxy up -d)
DOMAIN="example.com"
SSL_EMAIL="admin@example.com"
# Set to 1 to use Let's Encrypt staging (for testing — avoids rate limits)
SSL_STAGING=0

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Email Digest (optional — without SMTP_HOST, digests are logged but not sent)
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@community.local"
