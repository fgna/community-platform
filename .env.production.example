# Production environment template.
# Copy to .env on your production server and fill in all required values.
# Do NOT commit a populated .env file.
#
# Variables marked REQUIRED must be set — the application will refuse to start without them.
# Variables marked OPTIONAL can be left blank to disable the feature they control.

# ── Data directory ───────────────────────────────────────────────────────────
# All persistent data lives here. Back this directory up regularly.
DATA_DIR="/opt/community-platform/data"

# ── Database (REQUIRED) ──────────────────────────────────────────────────────
POSTGRES_USER="community"
POSTGRES_PASSWORD=""           # REQUIRED — use a strong random password
POSTGRES_DB="community_platform"
DATABASE_URL="postgresql://community:REPLACE_WITH_POSTGRES_PASSWORD@postgres:5432/community_platform"

# ── Redis (REQUIRED) ─────────────────────────────────────────────────────────
REDIS_URL="redis://redis:6379"

# ── JWT secrets (REQUIRED) ───────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=""                  # REQUIRED — 64+ hex chars
JWT_REFRESH_SECRET=""          # REQUIRED — 64+ hex chars (different from JWT_SECRET)
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=3001
NODE_ENV="production"

# ── Web ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="https://yourdomain.com"
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# ── CORS (REQUIRED) ──────────────────────────────────────────────────────────
# Comma-separated list of allowed origins — no wildcards
CORS_ORIGINS="https://yourdomain.com"

# ── HTTPS / Reverse proxy (REQUIRED for production) ──────────────────────────
DOMAIN="yourdomain.com"
SSL_EMAIL="admin@yourdomain.com"
SSL_STAGING=0                  # 0 = real Let's Encrypt certs; 1 = staging (for testing)

# ── Demo seed ─────────────────────────────────────────────────────────────────
# Keep false in production — prevents accidental creation of known demo accounts
SEED_DEMO_DATA=false

# ── Rate limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ── OAuth (OPTIONAL) ─────────────────────────────────────────────────────────
# Leave blank to disable social login buttons
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
# LINKEDIN_CLIENT_ID=""
# LINKEDIN_CLIENT_SECRET=""
# NEXT_PUBLIC_LINKEDIN_CLIENT_ID=""

# ── AI Coach (OPTIONAL) ──────────────────────────────────────────────────────
# Leave blank to disable AI Coach feature
# ANTHROPIC_API_KEY=""

# ── Stripe Billing (OPTIONAL) ────────────────────────────────────────────────
# Leave blank to disable billing features
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# STRIPE_PRICE_ID=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ── Email / SMTP (OPTIONAL) ──────────────────────────────────────────────────
# Without SMTP_HOST, email digests are logged but not sent
# SMTP_HOST=""
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="noreply@yourdomain.com"

# ── Mobile APK (OPTIONAL) ────────────────────────────────────────────────────
# Leave blank when APK is built into the Docker image by CI
# NEXT_PUBLIC_APK_URL=""
